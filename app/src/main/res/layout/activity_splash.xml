<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <LinearLayout
        android:id="@+id/statusBarFake"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="9:41"
            android:textColor="@color/text_dark"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▭  •••"
            android:textColor="@color/text_dark"
            android:textSize="16sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="86dp"
        android:layout_height="86dp"
        android:layout_marginTop="42dp"
        android:src="@drawable/logo"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toBottomOf="@id/statusBarFake"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart AudioBook"
        android:textColor="#00BFEA"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtLibrary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AudioBook Library"
        android:textColor="#4C63FF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/txtAppName"
        app:layout_constraintStart_toStartOf="@id/txtAppName"
        app:layout_constraintEnd_toEndOf="@id/txtAppName" />

    <FrameLayout
        android:id="@+id/progressTrack"
        android:layout_width="92dp"
        android:layout_height="5dp"
        android:layout_marginTop="68dp"
        android:background="@drawable/bg_progress_track"
        app:layout_constraintTop_toBottomOf="@id/txtLibrary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="58dp"
            android:layout_height="5dp"
            android:background="@drawable/bg_progress_fill" />
    </FrameLayout>

    <TextView
        android:id="@+id/txtLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading ..."
        android:textColor="@color/text_gray"
        android:textSize="11sp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/progressTrack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>